@page
@model BookingTicketCinema.ManagementApp.Pages.POS.POSHistoryModel
@{
    ViewData["Title"] = "Lịch sử Bán vé tại quầy";
}

<div class="container-fluid flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4">
        <span class="text-muted fw-light"></span> @ViewData["Title"]
    </h4>
    <p>Danh sách các hóa đơn bạn đã tạo tại quầy.</p>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.PaymentHistory.Items == null || !Model.PaymentHistory.Items.Any())
    {
        <div class="alert alert-info">Bạn chưa bán được vé nào.</div>
    }

    @foreach (var payment in Model.PaymentHistory.Items)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <strong class="fs-5">Hóa đơn #@payment.PaymentId</strong>
                    <span class="badge bg-@payment.StatusClass ms-2">@payment.StatusText</span>
                </div>
                <span class="text-muted">Ngày bán: @payment.CreatedAt.ToString("g")</span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-2">
                        <img src="@(Model.ApiBaseUrl + payment.PosterUrl)"
                             class="img-fluid rounded history-poster" alt="@payment.MovieTitle">
                    </div>
                    <div class="col-md-7">
                        <h4>@payment.MovieTitle</h4>
                        <p class="mb-1">
                            <i class="bx bx-calendar me-1"></i>
                            <strong>@payment.Showtime.ToString("HH:mm")</strong> - @payment.Showtime.ToString("dd/MM/yyyy")
                        </p>
                        <p class="mb-1">
                            <i class="bx bx-movie-play me-1"></i>
                            <strong>Phòng:</strong> @payment.RoomName
                        </p>
                        <p class="mb-1">
                            <i class="bx bx-chair me-1"></i>
                            <strong>Ghế:</strong>
                            @foreach (var ticket in payment.TicketsInPayment)
                            {
                                <span class="badge bg-dark me-1">@ticket.Seat</span>
                            }
                        </p>
                    </div>
                    <div class="col-md-3 border-start">
                        <h5 class="text-muted">Tổng cộng</h5>
                        <h3 class="text-danger fw-bold">@payment.Amount.ToString("N0") ₫</h3>

                        <div class="mt-3 d-grid">
                            <a asp-page="/POS/Receipt" asp-route-paymentId="@payment.PaymentId"
                               class="btn btn-primary">
                                <i class="bx bx-printer me-1"></i> In lại Hóa đơn
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (Model.PaymentHistory.TotalPages > 1)
    {
        <nav aria-label="Trang lịch sử">
            <ul class="pagination justify-content-center">

                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-page="/Profile/POSHistory" asp-route-p="@(Model.CurrentPage - 1)">Trước</a>
                </li>

                @for (var i = 1; i <= Model.PaymentHistory.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-page="/Profile/POSHistory" asp-route-p="@i">@i</a>
                    </li>
                }

                <li class="page-item @(Model.CurrentPage == Model.PaymentHistory.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-page="/Profile/POSHistory" asp-route-p="@(Model.CurrentPage + 1)">Sau</a>
                </li>
            </ul>
        </nav>
    }
</div>

<style>
    .history-poster {
        width: 100%; /* Cho nó tự co giãn theo cột .col-md-2 */
        max-width: 150px; /* Giới hạn chiều rộng tối đa */
        height: auto;
        object-fit: cover;
    }
</style>