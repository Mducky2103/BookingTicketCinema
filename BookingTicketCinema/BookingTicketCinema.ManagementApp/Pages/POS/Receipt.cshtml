@page
@model BookingTicketCinema.ManagementApp.Pages.POS.ReceiptModel
@{
    ViewData["Title"] = "Hóa đơn Bán vé";
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (Model.Receipt != null)
{
    <div class="row">
        <div class="col-lg-6 mx-auto">

            <div class="d-print-none d-flex justify-content-between mb-4">
                <a asp-page="/POS/Index" class="btn btn-primary">
                    <i class="bx bx-plus"></i> Bán vé mới
                </a>
                <button onclick="window.print()" class="btn btn-success">
                    <i class="bx bx-printer"></i> In Hóa đơn
                </button>
            </div>

            <div class="card" id="receipt-content">
                <div class="card-body p-4">
                    <h2 class="text-center text-primary">CINEMA TICKET</h2>
                    <p class="text-center text-muted">Hóa đơn: #@Model.Receipt.PaymentId</p>

                    <hr />

                    <h4 class="mb-3">@Model.Receipt.MovieTitle</h4>

                    <div class="row mb-2">
                        <div class="col-6">
                            <strong>Suất chiếu:</strong>
                        </div>
                        <div class="col-6 text-end">
                            @Model.Receipt.Showtime.ToString("HH:mm dd/MM/yyyy")
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-6">
                            <strong>Phòng:</strong>
                        </div>
                        <div class="col-6 text-end">
                            @Model.Receipt.RoomName
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-6">
                            <strong>Ghế:</strong>
                        </div>
                        <div class="col-6 text-end fw-bold">
                            @string.Join(", ", Model.Receipt.SeatNumbers)
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-6">
                            <strong>Số lượng:</strong>
                        </div>
                        <div class="col-6 text-end">
                            @Model.Receipt.SeatNumbers.Count vé
                        </div>
                    </div>

                    <hr class="my-3" />

                    <div class="d-flex justify-content-between fs-4">
                        <strong class="text-dark">TỔNG CỘNG</strong>
                        <strong class="text-danger">@Model.Receipt.Amount.ToString("N0") ₫</strong>
                    </div>

                    <hr class="my-3" />

                    <p class="text-center text-muted small">
                        Ngày xuất vé: @Model.Receipt.CreatedAt.ToString("g")<br />
                        Cảm ơn quý khách!
                    </p>
                </div>
            </div>
        </div>
    </div>
}

<style>
    @@media print {
        body {
            background-color: #fff;
        }
        /* Ẩn mọi thứ trừ hóa đơn khi in */
        .layout-navbar, .layout-menu, .d-print-none, .footer {
            display: none !important;
        }

        .layout-page {
            padding: 0 !important;
        }

        .container, .col-lg-6, .card {
            max-width: 100% !important;
            padding: 0 !important;
            margin: 0 !important;
            box-shadow: none !important;
            border: none !important;
        }
    }
</style>
