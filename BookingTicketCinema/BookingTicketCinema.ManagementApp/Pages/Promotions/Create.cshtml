@page
@model BookingTicketCinema.ManagementApp.Pages.Promotions.CreateModel
@{
    ViewData["Title"] = "Tạo Mã Khuyến mãi";
}

<h4 class="fw-bold py-3 mb-4">
    <span class="text-muted fw-light">Quản trị / Khuyến mãi /</span> @ViewData["Title"]
</h4>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Thông tin Mã khuyến mãi</h5>
            </div>
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Code" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="Input.Code" class="form-control" id="promo-code-input" />
                            <button type="button" class="btn btn-outline-secondary" id="btn-generate-code">
                                <i class="bx bx-refresh"></i> Tạo ngẫu nhiên
                            </button>
                        </div>
                        <span asp-validation-for="Input.Code" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.DiscountPercent" class="form-label"></label>
                        <input asp-for="Input.DiscountPercent" type="number" step="0.01" min="0.01" max="1.0" class="form-control" />
                        <span asp-validation-for="Input.DiscountPercent" class="text-danger"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Input.StartDate" class="form-label"></label>
                            <input asp-for="Input.StartDate" type="date" class="form-control" />
                            <span asp-validation-for="Input.StartDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.EndDate" class="form-label"></label>
                            <input asp-for="Input.EndDate" type="date" class="form-control" />
                            <span asp-validation-for="Input.EndDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Description" class="form-label"></label>
                        <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Input.Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="Input.IsActive" type="checkbox" class="form-check-input" />
                        <label asp-for="Input.IsActive" class="form-check-label"></label>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">Lưu</button>
                        <a asp-page="/Promotions/Index" class="btn btn-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const generateButton = document.getElementById("btn-generate-code");
            const codeInput = document.getElementById("promo-code-input");

            generateButton.addEventListener("click", function () {
                codeInput.value = generateRandomCode(8); // Tạo mã 8 ký tự
            });

            function generateRandomCode(length) {
                let result = '';
                // Bỏ các ký tự dễ nhầm lẫn (I, L, O, 0, 1)
                const characters = 'ABCDEFGHJKMNPQRSTUVWXYZ23456789';
                const charactersLength = characters.length;
                for (let i = 0; i < length; i++) {
                    result += characters.charAt(Math.floor(Math.random() * charactersLength));
                }
                return result;
            }
        });
    </script>
}
