@page
@model BookingTicketCinema.ManagementApp.Pages.Promotions.EditModel
@{
    ViewData["Title"] = "Cập nhật Khuyến mãi";
}

<h4 class="fw-bold py-3 mb-4">
    <span class="text-muted fw-light">Quản trị / Khuyến mãi /</span> @ViewData["Title"]
</h4>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Cập nhật Mã: <span class="text-primary">@Model.PromotionCode</span></h5>
            </div>
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label class="form-label">Mã Code</label>
                        <input class="form-control" value="@Model.PromotionCode" disabled />
                        <div class="form-text">Không thể thay đổi mã code sau khi tạo.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.DiscountPercent" class="form-label"></label>
                        <input asp-for="Input.DiscountPercent" type="number" step="0.01" min="0.01" max="1.0" class="form-control" />
                        <span asp-validation-for="Input.DiscountPercent" class="text-danger"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Input.StartDate" class="form-label"></label>
                            <input asp-for="Input.StartDate" type="date" class="form-control" />
                            <span asp-validation-for="Input.StartDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.EndDate" class="form-label"></label>
                            <input asp-for="Input.EndDate" type="date" class="form-control" />
                            <span asp-validation-for="Input.EndDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Description" class="form-label"></label>
                        <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Input.Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="Input.IsActive" type="checkbox" class="form-check-input" />
                        <label asp-for="Input.IsActive" class="form-check-label"></label>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                        <a asp-page="/Promotions/Index" class="btn btn-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
