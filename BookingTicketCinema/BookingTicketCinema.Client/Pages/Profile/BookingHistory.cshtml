@page
@model BookingTicketCinema.WebApp.Pages.Profile.BookingHistoryModel
@{
    ViewData["Title"] = "Lịch sử mua vé";

    // Gộp vé theo PaymentId (Đơn hàng)
    var payments = Model.Tickets
        .GroupBy(t => t.PaymentId) // (Bạn cần thêm PaymentId vào TicketHistoryDto)
        .Select(g => new
        {
            PaymentId = g.Key,
            FirstTicket = g.First(),
            Tickets = g.ToList()
        })
        .OrderByDescending(p => p.FirstTicket.CreatedAt);
}
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

<div class="container my-5">
    <h1>@ViewData["Title"]</h1>
    <p>Quản lý các vé đã đặt hoặc đang chờ thanh toán.</p>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    @if (!payments.Any())
    {
        <div class="alert alert-info">Bạn chưa có lịch sử đặt vé nào.</div>
    }

    @foreach (var paymentGroup in payments)
    {
        var firstTicket = paymentGroup.FirstTicket;
        var status = firstTicket.Status; // (0=Pending, 1=Booked, 2=Cancelled)

        string statusClass = status == 1 ? "success" : (status == 2 ? "danger" : "warning");
        string statusText = firstTicket.StatusText; // (Lấy từ ViewModel)

        <div class="card shadow-sm mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <strong>Đơn hàng #@paymentGroup.PaymentId</strong>
                    <span class="badge bg-@statusClass ms-2">@statusText</span>
                </div>
                <span class="text-muted">@firstTicket.CreatedAt.ToString("g")</span>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3">
                        <img src="@(Model.ApiBaseUrl + firstTicket.PosterUrl)"
                             class="img-fluid rounded history-poster" alt="@firstTicket.Movie">
                    </div>
                    <div class="col-md-9">
                        <h4>@firstTicket.Movie</h4>
                        <p class="mb-1">
                            <strong>Suất chiếu:</strong>
                            @firstTicket.StartTime.ToString("HH:mm") - @firstTicket.StartTime.ToString("dd/MM/yyyy")
                        </p>
                        <p class="mb-1"><strong>Phòng:</strong> @firstTicket.RoomName</p>
                        <p class="mb-1">
                            <strong>Ghế:</strong>
                            @foreach (var ticket in paymentGroup.Tickets)
                            {
                                <span class="badge bg-secondary me-1">@ticket.Seat</span>
                            }
                        </p>

                        <div class="mt-3">
                            @if (status == 1) // 0 = Pending (Đang chờ)
                            {
                                <a asp-page="/Booking/Checkout"
                                   asp-route-paymentId="@paymentGroup.PaymentId"
                                   class="btn btn-primary">
                                    <i class="bi bi-credit-card"></i> Thanh toán
                                </a>

                                <form method="post" asp-page-handler="Cancel" class="d-inline">
                                    <input type="hidden" name="paymentId" value="@paymentGroup.PaymentId" />
                                    <button type="submit" class="btn btn-outline-danger"
                                            onclick="return confirm('Bạn có chắc muốn hủy đơn hàng này?')">
                                        <i class="bi bi-x-circle"></i> Hủy vé
                                    </button>
                                </form>
                            }
                            else if (status == 2) // 1 = Booked (Đã thanh toán)
                            {
                                <a href="#" class="btn btn-success disabled">
                                    <i class="bi bi-qr-code"></i> Xem mã QR
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>