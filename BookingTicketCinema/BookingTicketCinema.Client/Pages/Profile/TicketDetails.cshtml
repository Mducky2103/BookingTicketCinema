@page
@model BookingTicketCinema.WebApp.Pages.Profile.TicketDetailsModel
@{
    ViewData["Title"] = "Chi tiết vé";
}

<style>
    .ticket-card {
        border: 2px dashed #0d6efd;
        background-color: #f8f9fa;
        border-radius: 15px;
    }
    .ticket-header {
        background-color: #0d6efd;
        color: white;
        padding: 1.5rem;
        border-radius: 12px 12px 0 0;
    }
    .ticket-body {
        padding: 2rem;
    }
    .ticket-qr {
        max-width: 250px;
        margin: auto;
        border: 5px solid #fff;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }
    .ticket-details .row {
        padding: 0.5rem 0;
        border-bottom: 1px solid #dee2e6;
    }
    .ticket-details .row:last-child {
        border-bottom: none;
    }
</style>

<div class="container my-5">
    <div class="row">
        <div class="col-lg-7 col-md-10 mx-auto">

            @if (Model.TicketDetails != null)
            {
                <div class="card shadow-lg ticket-card">
                    <div class="ticket-header text-center">
                        <h2 class="mb-0">VÉ XEM PHIM</h2>
                        <p class="mb-0">(Mã đơn hàng: #@Model.TicketDetails.PaymentId)</p>
                    </div>
                    <div class="ticket-body">
                        <div class="text-center mb-4">
                            @if (!string.IsNullOrEmpty(Model.QrCodeUrl))
                            {
                                <img src="@Model.QrCodeUrl" alt="QR Code" class="img-fluid ticket-qr" />
                            }
                            <p class="mt-2 text-muted">Vui lòng đưa mã này tại quầy soát vé</p>
                        </div>

                        <hr />

                        <h4 class="mb-3">@Model.TicketDetails.MovieTitle</h4>
                        <div class="ticket-details">
                            <div class="row">
                                <div class="col-5"><strong>Suất chiếu:</strong></div>
                                <div class="col-7 text-end fw-bold">@Model.TicketDetails.Showtime.ToString("HH:mm, dd/MM/yyyy")</div>
                            </div>
                            <div class="row">
                                <div class="col-5"><strong>Phòng:</strong></div>
                                <div class="col-7 text-end fw-bold">@Model.TicketDetails.RoomName</div>
                            </div>
                            <div class="row">
                                <div class="col-5"><strong>Ghế:</strong></div>
                                <div class="col-7 text-end fw-bold">@string.Join(", ", Model.TicketDetails.SeatNumbers)</div>
                            </div>
                            <div class="row">
                                <div class="col-5"><strong>Số lượng:</strong></div>
                                <div class="col-7 text-end">@Model.TicketDetails.SeatNumbers.Count vé</div>
                            </div>

                            <div class="row mt-3 fs-5">
                                <div class="col-5"><strong>Tổng cộng:</strong></div>
                                <div class="col-7 text-end fw-bold text-danger">@Model.TicketDetails.Amount.ToString("N0")đ</div>
                            </div>
                            <div class="row">
                                <div class="col-5"><strong>Trạng thái:</strong></div>
                                <div class="col-7 text-end fw-bold text-success">ĐÃ THANH TOÁN</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <a asp-page="/Profile/BookingHistory" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại Lịch sử
                    </a>
                </div>
            }
            else
            {
                <div class="alert alert-danger">
                    Không tìm thấy chi tiết vé.
                </div>
            }
        </div>
    </div>
</div>
